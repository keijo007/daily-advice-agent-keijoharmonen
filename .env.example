# ============================================================================
# Daily Insight Agent - Environment Configuration
# ============================================================================
# Copy this file to .env and fill in your values
# NEVER commit .env to git - it contains secrets!

# ============================================================================
# OPENAI CONFIGURATION (REQUIRED)
# ============================================================================
# Get your API key from: https://platform.openai.com/api-keys
# This key is PRIVATE - don't share it
OPENAI_API_KEY=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

# Which OpenAI model to use
# Recommended: gpt-4o-mini (cost-effective, good quality)
# Alternative: gpt-4o (better, more expensive), gpt-3.5-turbo (cheaper, lower quality)
OPENAI_MODEL=gpt-4o-mini

# ============================================================================
# DATA PATHS
# ============================================================================
# Path to your OneDrive-synced goals file
# Example: C:\Users\YourName\OneDrive\goals.txt
GOALS_FILE_PATH=

# Path to your OneDrive-synced diary file (optional)
# Example: C:\Users\YourName\OneDrive\diary.txt
DIARY_SYNC_PATH=

# ============================================================================
# AGENT CONFIGURATION
# ============================================================================
# How many past days of diary to analyze for reflection
DIARY_LOOKBACK_DAYS=7

# Token limits for API calls (affects cost and response depth)
# Reader Agent - summarizing new content
MAX_TOKENS_READER=1000

# Reflection Agent - analyzing your thoughts and biases
MAX_TOKENS_REFLECTION=1500

# Coach Agent - generating final insight and actionable tip
MAX_TOKENS_COACH=800

# ============================================================================
# CLOUD / ONEDRIVE CONFIGURATION (for Azure deployment)
# ============================================================================
# When deployed to cloud, read data from OneDrive instead of local machine

# Azure / Microsoft 365 credentials
# Get from: https://portal.azure.com → Azure Active Directory → App registrations
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_TENANT_ID=

# Enable OneDrive integration (true/false)
ONEDRIVE_ENABLED=false

# Cloud database connection (e.g., PostgreSQL in Azure)
# Leave empty to use local SQLite
DATABASE_URL=

# OneDrive folder paths (when ONEDRIVE_ENABLED=true)
# Example: /Documents/goals.txt
ONEDRIVE_GOALS_PATH=/Documents/goals.txt
ONEDRIVE_DIARY_FOLDER=/Diary

# ============================================================================
# FASTAPI CONFIGURATION
# ============================================================================
# Host and port for the web server
# 0.0.0.0 = accessible from network, localhost = local only
HOST=0.0.0.0
PORT=8000

# Debug mode (set to true for development)
DEBUG=false

# ============================================================================
# NOTES
# ============================================================================
# This agent reads from:
# - data/diary/ (local markdown/text files)
# - data/whatsapp_exports/ (WhatsApp export .txt files)
# - data/rss_sources.txt (RSS feed URLs)
# - GOALS_FILE_PATH (your OneDrive goals file)
#
# It saves:
# - insights.db (SQLite database with daily insights)
# - data/daily_insights/ (archived insights as JSON)
